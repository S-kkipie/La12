# Copy to .env.local and fill in as needed. Nothing here is required to run
# `pnpm build` — every integration falls back cleanly when its env var is
# missing (see the TODO(wire) comments in lib/*.ts).

# --- Off-chain data (SQLite + Drizzle, spec §6) ---
# Path to the SQLite file. Relative paths resolve against `web/`.
DATABASE_PATH=./ladoce.db

# --- Chain config (Sepolia testnet, spec §2) ---
# Used both client-side (wdk.ts, contracts.ts) and server-side (sync, sponsor).
# The default below (no API key) works for simple reads but rejects
# eth_getLogs beyond a small recent-block window — /api/sync needs a real
# provider key (Alchemy/Infura/drpc/etc.) to sync more than the last few blocks.
NEXT_PUBLIC_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
NEXT_PUBLIC_CHAIN_ID=11155111
# Server-only override if you want a different RPC for server code
# (sponsor.ts, /api/sync) than the one shipped to the browser. Defaults to
# NEXT_PUBLIC_RPC_URL when unset.
RPC_URL=

# Mock USD₮ (6 decimals) on Sepolia. TODO(wire): still open per spec §9 —
# pick a Pimlico/Candide mock USD₮ faucet address, or deploy MockUSDT.sol
# (contracts/src/MockUSDT.sol) and paste its address here.
NEXT_PUBLIC_USDT_ADDRESS=

# Amount minted per /api/faucet-usdt call, USD₮ base units (6 decimals).
# Only works against MockUSDT.sol, whose mint() is public/unrestricted by
# design (it's the faucet token) — local anvil or a testnet deploy only.
# Defaults to 5,000 USD₮ (5000000000). Requires SPONSOR_PK + NEXT_PUBLIC_USDT_ADDRESS.
FAUCET_USDT_AMOUNT=5000000000

# --- Gas sponsor (spec §5, "approach B") ---
# Relayer private key that pre-funds new fan wallets with a little Sepolia
# ETH so their first invest/claim tx has gas. Never touches the fan's own
# key. Leave unset to disable /api/faucet (it no-ops with a 503, doesn't crash).
SPONSOR_PK=
# Wei sent per faucet call. Defaults to 0.002 ETH (2000000000000000).
SPONSOR_FUND_WEI=2000000000000000

# --- MoonPay fiat on-ramp (spec §5 tier 3) ---
# TODO(wire): test credentials, once available (spec §9). Without
# MOONPAY_API_KEY, /api/moonpay returns an unsigned stub widget URL.
MOONPAY_API_KEY=
MOONPAY_SECRET_KEY=
