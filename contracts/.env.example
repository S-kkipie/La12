# Copy to contracts/.env and fill in for a real deploy. Not needed for
# `forge test` (local) — only for `forge script script/Deploy.s.sol`.

# Deployer key. Falls back to anvil's well-known dev key #0 for zero-config
# local runs (anvil). NEVER use the anvil key on a public network.
DEPLOYER_PK=

# Club payout wallet for the demo round. Defaults to the deployer address
# when unset.
CLUB_ADDRESS=

# Sepolia RPC endpoint for broadcasting.
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Example deploy:
#   DEPLOYER_PK=0x... CLUB_ADDRESS=0x... \
#   forge script script/Deploy.s.sol --rpc-url $SEPOLIA_RPC_URL --broadcast
